############################################
# Oqtane / ASP.NET Core
############################################

# Build results
bin/
obj/
out/

# Publish output
publish/
artifacts/

# Oqtane runtime folders
wwwroot/Modules/
wwwroot/Themes/
wwwroot/packages/
wwwroot/temp/

# Module & theme build output
**/ClientModules/**/dist/
**/ClientThemes/**/dist/

############################################
# Logs & runtime data
############################################
logs/
*.log

# Data Protection keys (DO NOT COMMIT)
DataProtectionKeys/
**/DataProtectionKeys/

############################################
# User secrets & config overrides
############################################
secrets.json
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

############################################
# Database / local data
############################################
*.mdf
*.ldf
*.db
*.sqlite

############################################
